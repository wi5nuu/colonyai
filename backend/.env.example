# Backend Environment Variables

# Application
APP_NAME=ColonyAI Backend
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/colonyai
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Supabase (Optional)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=colonyai-images
AWS_S3_ORIGINAL_PREFIX=original/
AWS_S3_ANNOTATED_PREFIX=annotated/
AWS_S3_URL_EXPIRY=3600

# JWT
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# YOLO Model
MODEL_PATH=./models/colony_best.pt
MODEL_CONFIDENCE_THRESHOLD=0.60
MODEL_IOU_THRESHOLD=0.45
MODEL_IMG_SIZE=512

# Image Processing
IMAGE_MAX_SIZE=10485760  # 10MB
IMAGE_ALLOWED_TYPES=image/jpeg,image/png,image/webp
PLATE_DETECTION_ENABLED=True

# Celery (Optional)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/colonyai.log
